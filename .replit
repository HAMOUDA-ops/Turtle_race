entrypoint = "main.py"
modules = ["python-3.11"]

[nix]
channel = "stable-24_05"

[agent]
expertMode = true

# أمر التشغيل الصحيح لفتح الشاشة الرسومية
run = "python3 main.py"

# إعدادات العرض التلقائي (الريغلاج السحري)
[split_views]
views = [
  { "view" = "vnc" }
]

[[ports]]
localPort = 5900
externalPort = 80
